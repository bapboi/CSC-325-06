<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="620.0" prefWidth="960.0" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.csc325_firebase_webview_auth.view.AccessFBView">
   <top>
      <MenuBar styleClass="app-menu-bar">
        <menus>
          <Menu mnemonicParsing="false" text="File">
            <items>
                  <MenuItem mnemonicParsing="false" onAction="#uploadPhoto" text="Upload Photo" />
                  <SeparatorMenuItem />
                  <MenuItem mnemonicParsing="false" onAction="#logout" text="Logout" />
              <MenuItem mnemonicParsing="false" onAction="#closeApp" text="Close" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Edit">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#deleteRecord" text="Delete Selected" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Theme">
            <items>
                  <MenuItem mnemonicParsing="false" onAction="#onThemeLight" text="Light" />
                  <MenuItem mnemonicParsing="false" onAction="#onThemeDark" text="Dark" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Help">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#showAbout" text="About" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
   <center>
      <BorderPane>
         <left>
            <VBox alignment="TOP_CENTER" prefWidth="150.0" spacing="14.0" styleClass="sidebar">
               <padding>
                  <Insets bottom="20.0" left="10.0" right="10.0" top="20.0" />
               </padding>
               <children>
                  <StackPane maxHeight="110.0" maxWidth="110.0" prefHeight="110.0" prefWidth="110.0" styleClass="profile-frame">
                     <children>
                        <Circle radius="45.0" styleClass="profile-circle" />
                        <ImageView fx:id="profileImageView" fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true" />
                     </children>
                  </StackPane>
                  <Label fx:id="welcomeLabel" alignment="CENTER" styleClass="sidebar-label" text="Welcome" textAlignment="CENTER" wrapText="true" />
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#uploadPhoto" styleClass="secondary-button" text="Change Photo" />
               </children>
            </VBox>
         </left>
         <center>
            <TableView fx:id="userTable" styleClass="data-table" BorderPane.alignment="CENTER">
              <columns>
                <TableColumn fx:id="nameColumn" prefWidth="200.0" text="Name" />
                <TableColumn fx:id="majorColumn" prefWidth="200.0" text="Major" />
                <TableColumn fx:id="ageColumn" prefWidth="110.0" text="Age" />
              </columns>
               <placeholder>
                  <Label text="No records yet" />
               </placeholder>
            </TableView>
         </center>
         <right>
            <VBox prefWidth="230.0" spacing="10.0" styleClass="form-panel">
               <padding>
                  <Insets bottom="16.0" left="14.0" right="14.0" top="20.0" />
               </padding>
               <children>
                  <Label styleClass="form-title" text="Add Record" />
                  <TextField fx:id="nameField" promptText="Name" styleClass="form-field" />
                  <TextField fx:id="majorField" promptText="Major" styleClass="form-field" />
                  <TextField fx:id="ageField" promptText="Age" styleClass="form-field" />
                  <HBox spacing="10.0">
                     <children>
                        <Button fx:id="readButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#readRecord" styleClass="action-button" text="Read" HBox.hgrow="ALWAYS" />
                        <Button fx:id="writeButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#addRecord" styleClass="action-button" text="Write" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </right>
      </BorderPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_LEFT" prefHeight="24.0" styleClass="status-bar">
         <padding>
            <Insets left="8.0" right="8.0" />
         </padding>
         <children>
            <Label fx:id="statusLabel" text="Ready." />
         </children>
      </HBox>
   </bottom>
</BorderPane>
